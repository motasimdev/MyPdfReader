<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <startup>
    <supportedRuntime version="v4.0" sku=".NETFramework,Version=v8.0,Profile=Windows"/>
  </startup>

  <appSettings>
    <!-- Default zoom step applied per click of the zoom in/out buttons -->
    <add key="ZoomStep" value="0.1"/>
    <!-- Minimum and maximum allowed zoom factors -->
    <add key="MinZoom" value="0.25"/>
    <add key="MaxZoom" value="4.0"/>
    <!-- Remembers the last folder used in the Open dialog -->
    <add key="RememberLastFolder" value="true"/>
  </appSettings>

  <runtime>
    <gcServer enabled="true"/>
  </runtime>
</configuration>
