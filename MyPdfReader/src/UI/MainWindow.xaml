<Window x:Class="MyPdfReader.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MyPdfReader"
        Height="800" Width="1100"
        MinHeight="400" MinWidth="600"
        WindowStartupLocation="CenterScreen"
        Icon="../Assets/App.ico">

    <Window.InputBindings>
        <!-- Keyboard shortcuts mirror the toolbar buttons -->
        <KeyBinding Key="O" Modifiers="Ctrl" Command="{x:Static ApplicationCommands.Open}"/>
    </Window.InputBindings>
    <Window.CommandBindings>
        <CommandBinding Command="{x:Static ApplicationCommands.Open}" Executed="OpenButton_Click"/>
    </Window.CommandBindings>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- Toolbar -->
            <RowDefinition Height="*"/>      <!-- Page viewer -->
            <RowDefinition Height="Auto"/>   <!-- Status bar -->
        </Grid.RowDefinitions>

        <!-- ===================== TOOLBAR ===================== -->
        <Border Grid.Row="0" Background="#F3F3F3" BorderBrush="#D8D8D8" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" Margin="6">

                <Button x:Name="OpenButton"
                        Style="{StaticResource ToolbarButtonStyle}"
                        Click="OpenButton_Click"
                        ToolTip="Open PDF (Ctrl+O)">
                    <Image Source="../Assets/icon-open.png" Width="20" Height="20"/>
                </Button>

                <Separator Margin="6,4" Width="1"/>

                <Button x:Name="PreviousButton"
                        Style="{StaticResource ToolbarButtonStyle}"
                        Click="PreviousButton_Click"
                        ToolTip="Previous page"
                        IsEnabled="False">
                    <TextBlock Text="◀" FontSize="14"/>
                </Button>

                <TextBox x:Name="PageNumberBox"
                         Width="40"
                         Margin="4,0"
                         VerticalContentAlignment="Center"
                         HorizontalContentAlignment="Center"
                         IsEnabled="False"
                         KeyDown="PageNumberBox_KeyDown"/>

                <TextBlock x:Name="PageCountText"
                           Text="/ 0"
                           VerticalAlignment="Center"
                           Margin="2,0,8,0"/>

                <Button x:Name="NextButton"
                        Style="{StaticResource ToolbarButtonStyle}"
                        Click="NextButton_Click"
                        ToolTip="Next page"
                        IsEnabled="False">
                    <Image Source="../Assets/icon-next.png" Width="20" Height="20"/>
                </Button>

                <Separator Margin="6,4" Width="1"/>

                <Button x:Name="ZoomOutButton"
                        Style="{StaticResource ToolbarButtonStyle}"
                        Click="ZoomOutButton_Click"
                        ToolTip="Zoom out"
                        IsEnabled="False">
                    <TextBlock Text="−" FontSize="18" FontWeight="Bold"/>
                </Button>

                <Button x:Name="ZoomInButton"
                        Style="{StaticResource ToolbarButtonStyle}"
                        Click="ZoomInButton_Click"
                        ToolTip="Zoom in"
                        IsEnabled="False">
                    <Image Source="../Assets/icon-zoom-in.png" Width="20" Height="20"/>
                </Button>

                <TextBlock x:Name="ZoomLevelText"
                           Text="100%"
                           VerticalAlignment="Center"
                           Margin="8,0"
                           MinWidth="40"/>

            </StackPanel>
        </Border>

        <!-- ===================== PAGE VIEWER ===================== -->
        <ScrollViewer Grid.Row="1"
                      Background="#808080"
                      HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Auto">
            <Grid>
                <!-- Shown when no document is open -->
                <TextBlock x:Name="EmptyStateText"
                           Text="Open a PDF file to get started (Ctrl+O)"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Foreground="White"
                           FontSize="16"/>

                <Border Background="White"
                        Margin="20"
                        Effect="{x:Null}"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                    <Image x:Name="PageImage"
                           Stretch="None"
                           SnapsToDevicePixels="True"/>
                </Border>
            </Grid>
        </ScrollViewer>

        <!-- ===================== STATUS BAR ===================== -->
        <Border Grid.Row="2" Background="#F3F3F3" BorderBrush="#D8D8D8" BorderThickness="0,1,0,0">
            <TextBlock x:Name="StatusText"
                       Text="No file open"
                       Margin="8,4"
                       FontSize="12"
                       Foreground="#555"/>
        </Border>

    </Grid>
</Window>
